---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';

const features = [
  {
    icon: '📅',
    title: 'Pagos recurrentes',
    description:
      'Agenda todos tus pagos fijos: renta, luz, internet, suscripciones. Calendario visual con swipe, historial y marcado de pagados.',
  },
  {
    icon: '💳',
    title: 'Deudas',
    description:
      'Registra lo que debes y lo que te deben. Simula plazos con o sin interés, y un semáforo financiero te dice qué tan comprometido estás cada mes.',
  },
  {
    icon: '🏦',
    title: 'Apartados',
    description:
      'Crea metas de ahorro para vacaciones, emergencias o lo que sea. Deposita y retira cuando quieras y ve tu progreso en tiempo real.',
  },
  {
    icon: '🤝',
    title: 'Tandas',
    description:
      'Lleva el registro de tu tanda sin papel: quién paga, cuándo te toca a ti y cuánto ha entrado en total.',
  },
  {
    icon: '🛒',
    title: 'Mercado',
    description:
      'Arma tu lista de compras con presupuesto en tiempo real. Tacha productos conforme los agregas al carrito y guarda el historial por establecimiento.',
  },
  {
    icon: '📊',
    title: 'Reportes',
    description:
      'Resumen visual de tus gastos por período: en qué se va más, cómo va tu salud financiera y cuánto tienes comprometido vs disponible.',
  },
];

const steps = [
  {
    num: '01',
    title: 'Descarga la beta',
    description:
      'Instala el APK gratuito en tu Android. No necesitas crear una cuenta ni darle ningún permiso extraño.',
  },
  {
    num: '02',
    title: 'Agrega lo que ya tienes',
    description:
      'Registra tus pagos fijos, tus deudas activas y tus metas de ahorro. Tarda menos de 5 minutos.',
  },
  {
    num: '03',
    title: 'Toma el control',
    description:
      'Cada vez que abras Bolsillo verás exactamente dónde estás parado. Sin sorpresas a fin de mes.',
  },
];
---

<Layout>
  <Header />

  <main>

      <section class="max-w-[1100px] mx-auto px-6 pt-20 pb-24 flex flex-col lg:flex-row items-center gap-14">

      <div class="flex-1 text-center lg:text-left">

        <span class="inline-block bg-brand-green-light text-brand-green text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
          ✦ Beta gratuita · Android 10+
        </span>

        <h1 class="font-display font-extrabold text-3xl md:text-5xl  leading-[1.08] text-brand-text mb-6">
          Organiza tu dinero.<br />
          <span class="text-brand-green">Sin complicaciones.</span>
        </h1>

        <p class="text-[18px] text-brand-muted leading-[1.75] mb-7 max-w-[500px] mx-auto lg:mx-0">
          Registra pagos, deudas, ahorros y listas del super — todo en tu celular,
          sin internet, sin registrarte, sin que nadie más vea tus datos.
        </p>

        <div class="flex items-start gap-3 bg-brand-green-light border-l-4 border-brand-green rounded-xl px-5 py-4 mb-8 max-w-[500px] mx-auto lg:mx-0">
          <span class="text-lg shrink-0 mt-0.5">🔒</span>
          <p class="text-sm font-medium text-brand-text leading-relaxed">
            Bolsillo no se conecta a ningún banco ni maneja tu dinero real —
            es una herramienta de organización personal, 100% offline.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-3 justify-center lg:justify-start mb-5">
          <button
            disabled
            class="w-full sm:w-auto bg-brand-green text-white font-semibold text-[16px] px-7 py-4 rounded-[14px] opacity-50 cursor-not-allowed text-center"
          >
            ⬇ Descargar APK Beta
          </button>
          <button
            disabled
            class="w-full sm:w-auto flex items-center justify-center gap-2 border border-brand-border text-brand-subtle font-medium text-[15px] px-7 py-4 rounded-[14px] cursor-not-allowed opacity-50"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.18 23.76c.3.17.65.19.97.07l12.45-7.2-2.79-2.79-10.63 9.92zM.32 1.12A1.5 1.5 0 0 0 0 2v20a1.5 1.5 0 0 0 .32.88l.1.1 11.2-11.2v-.26L.42 1.02l-.1.1zM20.46 10.37l-2.8-1.62-3.13 3.13 3.13 3.13 2.82-1.63a1.6 1.6 0 0 0 0-3zm-19.28 12.27 10.63-9.91-2.79-2.79-7.84 12.7z"/>
            </svg>
            Próximamente en Google Play
          </button>
        </div>

        <div class="flex items-center gap-2 justify-center lg:justify-start mb-1">
          <span class="inline-block w-2 h-2 rounded-full bg-brand-amber animate-pulse"></span>
          <p class="text-sm text-brand-subtle">
            Acceso controlado —
            <a href="mailto:lalonso.dev@gmail.com?subject=Quiero acceso a la beta de Bolsillo" class="text-brand-green font-medium hover:underline">
              escríbeme para unirte a la beta
            </a>
          </p>
        </div>
        <p class="text-sm text-brand-subtle text-center lg:text-left">
          Sin registro &nbsp;·&nbsp; Sin publicidad
        </p>
      </div>

      <div class="shrink-0 relative">
        <div class="absolute inset-0 -z-10 rounded-full bg-brand-green-glow blur-[80px] opacity-60 scale-110"></div>

        <div class="w-full sm:w-[80%] md:w-[360px] mx-auto">
          <img src="/5shots_so.png" alt="Bolsillo" class="w-full h-full object-cover" loading="lazy" width="360" height="640">
        </div>
      </div>
    </section>

    
    <div class="bg-white border-y border-brand-border py-10">
      <div class="max-w-[900px] mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-0 divide-x divide-brand-border">
          {[
            { num: '100%', label: 'Privado y local'    },
            { num: '$0',   label: 'Para empezar'       },
            { num: '6',    label: 'Módulos incluidos'  },
            { num: '∞',    label: 'Sin anuncios nunca' },
          ].map(s => (
            <div class="flex flex-col items-center justify-center py-4 px-6 gap-1">
              <span class="font-display font-extrabold text-[3rem] leading-none text-brand-green">
                {s.num}
              </span>
              <span class="text-sm text-brand-subtle text-center">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    
    <section id="caracteristicas" class="max-w-[1100px] mx-auto px-6 py-24">
      <div class="text-center mb-14">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-brand-subtle mb-3">
          Todo lo que necesitas
        </span>
        <h2 class="font-display font-bold text-4xl text-brand-text mb-4 leading-tight">
          Seis módulos para tener<br class="hidden sm:block" /> tus finanzas bajo control.
        </h2>
        <p class="text-[17px] text-brand-muted max-w-[520px] mx-auto leading-relaxed">
          Desde pagar la renta hasta armar la despensa — Bolsillo cubre
          cada aspecto de tu vida financiera diaria.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {features.map(f => (
          <FeatureCard icon={f.icon} title={f.title} description={f.description} />
        ))}
      </div>
    </section>

    
    <section class="bg-white py-24">
      <div class="max-w-[1100px] mx-auto px-6">
        <div class="text-center mb-16">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-brand-subtle mb-3">
            Por qué Bolsillo
          </span>
          <h2 class="font-display font-bold text-4xl text-brand-text mb-4 leading-tight">
           Sin servidores.<br />Sin excusas.
          </h2>
          <p class="text-[17px] text-brand-muted max-w-[480px] mx-auto leading-relaxed">
            Construida desde cero pensando en tu privacidad. No necesitas
            confiarle tus datos a nadie para organizarte.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
          {[
            {
              icon: '🔒',
              title: '100% privado',
              desc: 'Toda la información vive en tu teléfono. Sin cuenta, sin email, sin rastreo. Ni nosotros sabemos qué guardas en Bolsillo.',
            },
            {
              icon: '📴',
              title: 'Funciona sin internet',
              desc: 'Abre Bolsillo en el super, en el metro o en el rancho sin señal. Funciona completamente offline, siempre, sin excepciones.',
            },
            {
              icon: '💾',
              title: 'Tu backup, tus reglas',
              desc: 'Exporta tu base de datos como un archivo y guárdalo donde quieras: Drive, USB, WhatsApp. Tú decides. Y restáuralo igual de fácil.',
            },
          ].map(p => (
            <div class="flex flex-col items-center gap-4">
              <div class="w-16 h-16 bg-brand-green-light rounded-2xl flex items-center justify-center text-3xl">
                {p.icon}
              </div>
              <h3 class="font-sans font-bold text-[20px] text-brand-text">{p.title}</h3>
              <p class="text-[15px] text-brand-muted leading-[1.7] max-w-[280px]">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    
    <section id="como-funciona" class="max-w-[1100px] mx-auto px-6 py-24">
      <div class="text-center mb-14">
        <span class="inline-block text-xs font-bold uppercase tracking-widest text-brand-subtle mb-3">
          Cómo funciona
        </span>
        <h2 class="font-display font-bold text-4xl text-brand-text mb-4">
          En tres pasos<br />empiezas hoy.
        </h2>
        <p class="text-[17px] text-brand-muted max-w-[400px] mx-auto leading-relaxed">
          Sin tutoriales de 30 minutos ni configuraciones complejas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {steps.map(s => (
          <div class="relative bg-white border border-brand-border rounded-3xl p-8 shadow-level-1 overflow-hidden">
            <span class="absolute -top-3 -right-1 font-display font-black text-[96px] leading-none text-brand-green-light select-none pointer-events-none">
              {s.num}
            </span>
            <div class="relative z-10">
              <p class="text-xs font-bold uppercase tracking-widest text-brand-green mb-3">
                Paso {s.num}
              </p>
              <h3 class="font-sans font-bold text-[20px] text-brand-text mb-3">{s.title}</h3>
              <p class="text-[15px] text-brand-muted leading-relaxed">{s.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    
    <section id="precios" class="bg-white py-24">
      <div class="max-w-[1100px] mx-auto px-6">
        <div class="text-center mb-14">
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-brand-subtle mb-3">
            Precios
          </span>
          <h2 class="font-display font-bold text-4xl text-brand-text mb-4 leading-tight">
            Gratis para empezar.<br />Premium cuando lo necesites.
          </h2>
          <p class="text-[17px] text-brand-muted max-w-[480px] mx-auto leading-relaxed">
            No te cobraremos por funciones básicas nunca. El Premium amplía
            los límites cuando tu vida financiera lo pida.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-[800px] mx-auto">

          <div class="bg-brand-bg border border-brand-border rounded-3xl p-9">
            <p class="text-xs font-bold uppercase tracking-widest text-brand-subtle mb-3">Gratuito</p>
            <div class="flex items-end gap-2 mb-1">
              <span class="font-display font-extrabold text-[3.2rem] leading-none text-brand-text">$0</span>
              <span class="text-[16px] text-brand-subtle mb-1">/mes</span>
            </div>
            <p class="text-sm text-brand-subtle mb-7">Para siempre, sin tarjeta</p>

            <div class="border-t border-brand-border pt-7 space-y-3.5 mb-8">
              {[
                'Hasta 3 pagos recurrentes',
                '1 deuda activa',
                '2 apartados',
                'Lista de mercado básica',
                'Reportes del mes actual',
                'Alertas locales',
                'Backup y restauración',
              ].map(f => (
                <div class="flex items-start gap-3 text-[15px] text-brand-muted">
                  <span class="text-brand-green font-bold mt-0.5">✓</span>
                  <span>{f}</span>
                </div>
              ))}
            </div>

            <button
              disabled
              class="block w-full border border-brand-border text-brand-subtle font-semibold py-3.5 rounded-[14px] cursor-not-allowed opacity-50 text-[15px]"
            >
              Descargar gratis →
            </button>
          </div>

          <div class="bg-white border-2 border-brand-green rounded-3xl p-9 shadow-level-3">
            <span class="inline-block bg-brand-amber-bg text-brand-amber-text text-xs font-bold uppercase tracking-wide px-4 py-1.5 rounded-full mb-5">
              ⏳ Próximamente
            </span>

            <p class="text-xs font-bold uppercase tracking-widest text-brand-green mb-3">Premium</p>
            <div class="flex items-end gap-2 mb-1">
              <span class="font-display font-extrabold text-[3.2rem] leading-none text-brand-text">$X</span>
              <span class="text-[16px] text-brand-subtle mb-1">/mes o $Y/año</span>
            </div>
            <p class="text-sm text-brand-subtle mb-7">Disponible al lanzamiento en Play Store</p>

            <div class="border-t border-brand-border pt-7 space-y-3.5 mb-8">
              {[
                'Todo del plan gratuito',
                'Pagos, deudas y apartados ilimitados',
                'Módulo de Tandas completo',
                'Simulador de deudas con interés',
                'Exportar reportes en PDF',
                'Salud financiera avanzada',
                'Soporte prioritario',
              ].map(f => (
                <div class="flex items-start gap-3 text-[15px] text-brand-text">
                  <span class="text-brand-green font-bold mt-0.5">✓</span>
                  <span>{f}</span>
                </div>
              ))}
            </div>

            <button
              disabled
              class="block w-full bg-brand-green text-white font-semibold py-3.5 rounded-[14px] opacity-50 cursor-not-allowed text-[15px]"
            >
              Próximamente →
            </button>
          </div>
        </div>

        <p class="text-center text-sm text-brand-subtle mt-8 max-w-[500px] mx-auto leading-relaxed">
          El plan Premium se activará con el lanzamiento oficial en Google Play.
          La beta siempre es gratuita y sin límites durante el período de prueba.
        </p>
      </div>
    </section>

   
    <section class="max-w-[1100px] mx-auto px-6 py-10">
      <div class="bg-brand-green rounded-[24px] px-8 sm:px-16 py-20 text-center">

        <p class="text-xs font-bold uppercase tracking-widest text-[#a7f3d0] mb-5">
          Beta disponible ahora
        </p>

        <h2 class="font-display font-extrabold text-4xl sm:text-5xl text-white leading-[1.1] mb-5 max-w-[560px] mx-auto">
          La beta de Bolsillo está lista para tu Android.
        </h2>

        <p class="text-[18px] text-[#bbf7d0] leading-[1.7] max-w-[440px] mx-auto mb-10">
          Descárgala gratis, pruébala con tus finanzas reales y cuéntanos
          qué le agregarías. Cada reporte de usuario mejora la app.
        </p>

        <button
          disabled
          class="inline-block bg-white text-brand-green font-bold text-[16px] px-10 py-4 rounded-[14px] opacity-50 cursor-not-allowed"
        >
          ⬇ Descargar APK Beta
        </button>

        <p class="text-[#86efac] text-sm mt-5">
          Acceso por invitación —
          <a
            href="mailto:lalonso.dev@gmail.com?subject=Quiero acceso a la beta de Bolsillo"
            class="font-semibold underline underline-offset-2 hover:text-white transition-colors"
          >
            escríbeme para unirte
          </a>
        </p>

        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mt-4 text-sm text-[#86efac]">
          <span>Gratis</span>
          <span class="text-[#4ade80]">·</span>
          <span>Sin registro</span>
          <span class="text-[#4ade80]">·</span>
          <span>Android 10+</span>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

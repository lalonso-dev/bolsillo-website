---
---

<header id="site-header" class="w-full bg-white border-b border-brand-border sticky top-0 z-50 transition-shadow duration-200">
  <div class="max-w-[1100px] mx-auto px-6 h-[68px] flex items-center justify-between gap-6">

    <a href="/" class="flex items-center gap-2.5 shrink-0">
      <img src="/logo.svg" alt="Bolsillo" class="w-9 h-9 rounded-[10px]" />
      <span class="font-display font-bold text-xl text-brand-text">Bolsillo</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-[15px] font-medium text-brand-muted">
      <a href="/#caracteristicas" class="hover:text-brand-green transition-colors">Características</a>
      <a href="/#como-funciona" class="hover:text-brand-green transition-colors">Cómo funciona</a>
      <a href="/#precios" class="hover:text-brand-green transition-colors">Precios</a>
    </nav>

    <div class="flex items-center gap-2.5 shrink-0">
      <button
        disabled
        class="inline-flex items-center gap-1.5 px-4 py-2.5 text-sm font-semibold text-white bg-brand-green rounded-[12px] opacity-50 cursor-not-allowed"
      >
        Descargar APK
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('shadow-level-2', window.scrollY > 8);
  }, { passive: true });
</script>
